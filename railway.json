{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./mvnw clean package",
    "env": {
      "JAVA_VERSION": "17"
    }
  },
  "deploy": {
    "startCommand": "java -jar target/theater-booking-0.0.1-SNAPSHOT.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
} 